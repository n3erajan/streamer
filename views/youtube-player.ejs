<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title><%= title %></title>
  <meta name="referrer" content="no-referrer">
  <link rel="icon" href="/favicon.ico">

  <meta property="og:type"        content="video.movie" />
  <meta property="og:title"       content="<%= title %>" />
  <meta property="og:description" content="<%= description %>" />
  <meta property="og:url"         content="<%= pageUrl %>" />
  <% if (thumb) { %><meta property="og:image" content="<%= thumb %>" /><% } %>
  <meta property="og:video"       content="<%= videoUrl %>" />
  <meta property="og:video:type"  content="video/mp4" />
  <meta property="og:video:secure_url" content="<%= videoUrl %>" />
  <meta name="og:author" content="neerajan" />
  <meta name="author" content="neerajan" />
  <meta property="og:site_name" content="YouTube" />
  <meta property="al:android:app_name" content="YouTube" />
  <meta property="al:ios:app_name" content="YouTube" />
  <meta name="application-name" content="YouTube" />
  <meta property="og:provider" content="YOUTUBE" />

  <link rel="alternate" type="application/x-mpegURL" href="/api/hls/youtube/<%= videoId %>.m3u8">

  <link rel="stylesheet" href="https://cdn.plyr.io/3.7.8/plyr.css" />
  <%- include('partials/styles') %>
  <style>
    .cinema-wrap{
      width:100%;
      max-width:1000px;
      margin:0 auto;
    }
    .video-frame{
      background:#000;
      border-radius:var(--radius-lg) var(--radius-lg) 0 0;
      overflow:hidden;
      box-shadow:0 16px 48px rgba(0,0,0,0.7);
      position:relative;
    }
    video{width:100%;display:block;background:#000}

    .video-info{
      background:var(--surface);
      border:1px solid var(--surface-border);
      border-top:none;
      border-radius:0 0 var(--radius-lg) var(--radius-lg);
      padding:24px 28px 28px;
      position:relative;
    }
    .video-info h2{
      font-size:1.3rem;
      font-weight:700;
      color:var(--text);
      letter-spacing:-0.01em;
      line-height:1.3;
      padding-right:110px;
    }
    .video-info small{
      color:var(--text-secondary);
      font-size:0.85rem;
      font-weight:500;
    }
    .video-info > p{
      color:var(--text-secondary);
      line-height:1.65;
      font-size:0.9rem;
      margin-top:14px;
      max-width:60ch;
    }

    .btn-share{
      position:absolute;
      right:28px;
      top:24px;
      padding:8px 18px;
      border-radius:var(--radius);
      background:var(--accent);
      color:#fff;
      border:none;
      cursor:pointer;
      font-family:inherit;
      font-size:0.82rem;
      font-weight:600;
      transition:background 0.2s, transform 0.15s;
    }
    .btn-share:hover{background:var(--accent-hover)}
    .btn-share:active{transform:scale(0.96)}


    /* ── Related ── */
    .related{
      margin-top:48px;
      width:100%;max-width:1000px;
      margin-left:auto;margin-right:auto;
      padding:0 40px 80px;
      position:relative;z-index:1;
    }
    .related h3{
      font-size:1.2rem;
      font-weight:700;
      color:var(--text);
      margin-bottom:20px;
      letter-spacing:-0.01em;
    }

    @media(max-width:768px){
      .video-info{padding:20px}
      .video-info h2{font-size:1.15rem;padding-right:100px}
      .btn-share{right:20px;top:20px;padding:7px 14px}
      .related{padding:0 20px 60px}
    }

    /* ── Fullscreen overrides ── */
    .yt-player-fullscreen { overflow: hidden; }
    .yt-player-fullscreen .global-nav,
    .yt-player-fullscreen .related,
    .yt-player-fullscreen .video-info,
    .yt-player-fullscreen footer,
    .yt-player-fullscreen .main-container > :not(.cinema-wrap) { display:none !important; }
    .yt-player-fullscreen .main-container { padding:0 !important; margin:0 !important; height:100vh; width:100vw; display:flex; justify-content:center; align-items:center; }
    .yt-player-fullscreen .cinema-wrap { max-width:none !important; margin:0 !important; width:100%; height:100%; }
    .yt-player-fullscreen .video-frame { border-radius:0 !important; box-shadow:none !important; width:100%; height:100%; display:flex; }
    .yt-player-fullscreen video { height:100% !important; object-fit:contain; }
    .yt-player-fullscreen .plyr { width:100%; height:100%; }

    .loader-container {
      display: flex;
      justify-content: center;
      padding: 30px 0;
      opacity: 0;
      transition: opacity 0.3s;
    }
    .loader-container.active {
      opacity: 1;
    }
    .spinner {
      width: 32px;
      height: 32px;
      border: 3px solid var(--surface-border);
      border-top-color: var(--accent);
      border-radius: 50%;
      animation: spin 1s linear infinite;
    }
    @keyframes spin {
      to { transform: rotate(360deg); }
    }
  </style>
</head>
<body>
  <%- include('partials/nav') %>

  <main class="main-container" style="display:flex; flex-direction:column; align-items:center;">
    <div class="cinema-wrap">
      <div class="video-frame" id="player-container">
        <video id="player" playsinline webkit-playsinline preload="metadata" poster="<%= thumb || '' %>" src="<%= videoUrl %>"></video>
      </div>
      <div class="video-info">
        <button class="btn-share" onclick="navigator.clipboard.writeText(window.location.href); this.innerText='Copied!'; setTimeout(() => this.innerText='Share Link', 2000)">Share Link</button>
        <h2><%= title %></h2>
        <small><%= channel %></small>
        <p style="margin-top:12px;color:var(--text-secondary);line-height:1.65;font-size:0.9rem"><%= description %></p>
        

      </div>
    </div>
  </main>

  <% if (relatedVideos && relatedVideos.length > 0) { %>
  <div class="related" id="related-container">
    <h3>Related Videos</h3>
    <div class="grid" id="related-grid">
      <% relatedVideos.forEach(v => { %>
        <a class="card" href="/youtube/watch/<%= v.id %>">
          <div class="thumb-wrap">
            <img src="<%= v.thumbnail %>" alt="<%= v.title %>" loading="lazy" />
            <% if (v.duration) { %><span class="duration-badge"><%= Math.floor(v.duration / 60) %>:<%= String(v.duration % 60).padStart(2, '0') %></span><% } %>
          </div>
          <div class="card-info">
            <div class="card-title"><%= v.title %></div>
            <div class="card-meta"><%= v.channel %></div>
          </div>
        </a>
      <% }) %>
    </div>
    
    <% if (relatedContinuation) { %>
      <div class="loader-container" id="scroll-loader" data-token="<%= relatedContinuation %>" data-videoid="<%= videoId %>">
        <div class="spinner"></div>
      </div>
    <% } %>
  </div>
  <% } %>

  <script src="https://cdn.plyr.io/3.7.8/plyr.polyfilled.js"></script>
  <script>
    const v = document.getElementById('player');
    console.log('[yt-player] video src:', v ? v.src : 'no element');
    console.log('[yt-player] videoUrl from template:', '<%= videoUrl %>');
    v.addEventListener('error', () => {
      console.error('[yt-player] video error:', v.error ? v.error.message : 'unknown', v.networkState);
    });
    v.addEventListener('loadstart', () => console.log('[yt-player] loadstart'));
    v.addEventListener('waiting', () => console.log('[yt-player] waiting'));
    v.addEventListener('canplay', () => console.log('[yt-player] canplay'));
    
    // Initialize Plyr
    const player = new Plyr(v, {
      controls: ['play-large', 'play', 'progress', 'current-time', 'mute', 'volume', 'fullscreen'],
      autoplay: true
    });

    // ── Quality picker ───────────────────────────────────────────────────
    const videoId = '<%= videoId %>';
    let formats = [];
    let currentItag = null;
    let upgradePending = false; // true once formats are loaded, pending auto-upgrade after playback starts
    let playbackStartedAt = 0;  // timestamp when the 360p stream first started playing
    let upgradeTimer = null;    // delayed auto-upgrade timer (cleared on navigation)

    // Minimum seconds of stable 360p playback before auto-upgrading.
    // This ensures the user sees the video playing immediately, and the
    // upgrade only happens once the initial stream is stable.
    const AUTO_UPGRADE_DELAY_S = 5;

    // Auto-upgrade fires after the 360p stream has been playing stably for
    // AUTO_UPGRADE_DELAY_S seconds. The old code upgraded on the FIRST
    // 'playing' event, which immediately aborted the working 360p stream and
    // started a slow yt-dlp subprocess for 1080p — causing the video to stall.
    v.addEventListener('playing', function onFirstPlay() {
      v.removeEventListener('playing', onFirstPlay);
      
      // If the fallback yt-dlp method was used, the stream might ALREADY be 1080p.
      // If so, cancel the auto-upgrade so we don't cause a blackout refresh.
      if (v.videoWidth >= 1280) {
        console.log('[yt-player] Initial video is already HD (' + v.videoWidth + 'x' + v.videoHeight + '), skipping auto-upgrade.');
        upgradePending = false;
        
        const currentSpan = document.getElementById('q-current');
        if (currentSpan) currentSpan.textContent = (v.videoHeight >= 720 ? v.videoHeight + 'p' : 'HD');
        
        return;
      }

      playbackStartedAt = Date.now();
      if (upgradePending) {
        scheduleAutoUpgrade();
      }
    });

    function scheduleAutoUpgrade() {
      if (upgradeTimer) return; // already scheduled
      const elapsed = (Date.now() - playbackStartedAt) / 1000;
      const remaining = Math.max(0, AUTO_UPGRADE_DELAY_S - elapsed);
      console.log('[yt-player] Auto-upgrade scheduled in', remaining.toFixed(1), 's');
      upgradeTimer = setTimeout(() => {
        upgradeTimer = null;
        autoUpgrade();
      }, remaining * 1000);
    }

    // Inject quality button + menu into Plyr's control bar after it renders
    function injectQualityUI() {
      const ctrls = document.querySelector('.plyr__controls');
      if (!ctrls) { setTimeout(injectQualityUI, 100); return }

      // Insert before the fullscreen button
      const fsBtn = ctrls.querySelector('[data-plyr="fullscreen"]');
      const ref = fsBtn || ctrls.lastElementChild;

      // Build the quality button (settings gear)
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'plyr__control';
      btn.id = 'btn-quality';
      btn.setAttribute('aria-label', 'Quality');
      btn.innerHTML =
        '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>' +
        '<span id="q-current" style="font-size:0.7rem;margin-left:2px">360p</span>';

      // Build the dropdown menu
      const menu = document.createElement('div');
      menu.id = 'quality-menu';
      menu.className = 'quality-menu';
      menu.innerHTML = '<div class="quality-menu-loading" id="q-loading">Loading…</div>';

      // Wrap them in a container
      const wrap = document.createElement('div');
      wrap.className = 'plyr__controls__item quality-wrap';
      wrap.appendChild(btn);
      wrap.appendChild(menu);
      ctrls.insertBefore(wrap, ref);

      // Toggle on button click
      btn.addEventListener('click', (e) => { e.stopPropagation(); menu.classList.toggle('open') });

      // Close on outside click
      document.addEventListener('click', (e) => {
        if (!wrap.contains(e.target)) menu.classList.remove('open');
      }, true);

      // Fetch formats in background
      fetchFormats();
    }

    // Append quality styles dynamically
    const qStyle = document.createElement('style');
    qStyle.textContent = `
      .quality-wrap{position:relative}
      .quality-menu{
        position:absolute;bottom:100%;right:-8px;margin-bottom:8px;
        background:rgba(24,24,28,0.96);border:1px solid rgba(255,255,255,0.08);
        border-radius:10px;padding:6px 0;min-width:170px;
        box-shadow:0 8px 32px rgba(0,0,0,0.6);display:none;
        z-index:30;max-height:260px;overflow-y:auto;
        backdrop-filter:blur(16px);
      }
      .quality-menu.open{display:block}
      .quality-menu-item{
        display:flex;align-items:center;gap:6px;padding:7px 14px;cursor:pointer;
        font-size:0.82rem;color:rgba(255,255,255,0.9);transition:background 0.1s;
        white-space:nowrap;
      }
      .quality-menu-item:hover{background:rgba(255,255,255,0.1)}
      .quality-menu-item .q-label{font-weight:600;flex:1}
      .quality-menu-item .q-check{width:16px;text-align:center;flex-shrink:0;font-size:0.75rem}
      .quality-menu-item.active{background:var(--accent);color:#fff}
      .quality-menu-loading{padding:14px 16px;text-align:center;color:rgba(255,255,255,0.45);font-size:0.82rem}
      .quality-menu-error{padding:14px 16px;text-align:center;color:var(--accent);font-size:0.8rem}
    `;
    document.head.appendChild(qStyle);
    injectQualityUI();

    // Fetch formats from API — stores them for the quality menu and flags
    // that auto-upgrade should happen once the video starts playing at 360p.
    async function fetchFormats() {
      const loading = document.getElementById('q-loading');
      try {
        const res = await fetch('/api/youtube/formats/' + videoId);
        const data = await res.json();
        if (!data.formats || !data.formats.length) {
          if (loading) loading.textContent = 'No formats';
          return;
        }
        formats = data.formats;
        renderQualityMenu();
        upgradePending = true;

        // Pre-warm: start resolving the best upgrade URL in the background
        // so it's cached on the server by the time autoUpgrade fires.
        const best = pickBestUpgrade();
        if (best && !best.url) {
          console.log('[yt-player] Pre-warming upgrade URL for itag', best.itag, best.quality);
          fetch('/youtube-stream/' + videoId + '.mp4?itag=' + best.itag + '&json=1').catch(() => {});
        }

        // If video is already playing (formats loaded very fast), schedule
        // the delayed upgrade instead of upgrading immediately.
        if (playbackStartedAt > 0) {
          scheduleAutoUpgrade();
        }
      } catch (e) {
        if (loading) loading.textContent = 'Error';
      }
    }

    // Pick the best upgrade candidate (highest quality with video+audio, above 360p).
    // Extracted into a helper so both fetchFormats (pre-warm) and autoUpgrade use
    // the same logic.
    function pickBestUpgrade() {
      const candidates = formats.filter(f => f.hasVideo && f.hasAudio);
      if (!candidates.length) return null;

      const tiers = {};
      for (const f of candidates) {
        const key = f.quality;
        if (!tiers[key] || (f.filesize && (!tiers[key].filesize || f.filesize > tiers[key].filesize))) {
          tiers[key] = f;
        }
      }

      const sorted = Object.values(tiers).sort((a, b) => {
        const ha = parseInt(a.quality) || 0;
        const hb = parseInt(b.quality) || 0;
        return hb - ha;
      });

      const best = sorted[0];
      if (!best || (parseInt(best.quality) || 0) <= 360) return null;
      return best;
    }

    function autoUpgrade() {
      upgradePending = false; // only upgrade once per video

      const best = pickBestUpgrade();
      if (!best) return;

      // Only auto-upgrade if the format has a pre-resolved URL (from yt-dlp's
      // -J output). If it doesn't, the server would need to spawn a fresh
      // yt-dlp process (30-60s) which would stall playback. The user can still
      // manually pick quality from the menu — that's an explicit action where
      // a brief wait is acceptable.
      if (best.url) {
        console.log('[yt-player] Auto-upgrading to', best.quality, '(direct URL available)');
        selectQuality(best.itag, best.quality);
      } else {
        console.log('[yt-player] Skipping auto-upgrade to', best.quality, '(no direct URL, would need yt-dlp subprocess)');
      }
    }

    function renderQualityMenu() {
      const menu = document.getElementById('quality-menu');
      if (!menu) return;

      const candidates = formats.filter(f => f.hasVideo && f.hasAudio);

      // Group by quality, pick best per tier
      const tiers = {};
      for (const f of candidates) {
        const key = f.quality;
        if (!tiers[key] || (f.filesize && (!tiers[key].filesize || f.filesize > tiers[key].filesize))) {
          tiers[key] = f;
        }
      }

      const sorted = Object.values(tiers).sort((a, b) => {
        const ha = parseInt(a.quality) || 0;
        const hb = parseInt(b.quality) || 0;
        return hb - ha;
      });

      let html = '';
      for (const f of sorted) {
        const active = f.itag === currentItag ? 'active' : '';
        const check = f.itag === currentItag ? '✓' : '';
        html += '<div class="quality-menu-item ' + active + '" data-itag="' + f.itag + '" data-quality="' + f.quality + '">';
        html += '<span class="q-check">' + check + '</span>';
        html += '<span class="q-label">' + f.quality + '</span>';
        html += '</div>';
      }
      menu.innerHTML = html || '<div class="quality-menu-error">No playable formats</div>';

      menu.querySelectorAll('.quality-menu-item').forEach(el => {
        el.addEventListener('click', () => {
          selectQuality(el.dataset.itag, el.dataset.quality);
        });
      });
    }

    function selectQuality(itag, quality) {
      if (itag === currentItag) return;
      currentItag = itag;
      const currentSpan = document.getElementById('q-current');
      if (currentSpan) currentSpan.textContent = quality;

      const menu = document.getElementById('quality-menu');
      if (menu) menu.classList.remove('open');

      // Cancel any pending auto-upgrade — the user made an explicit choice
      if (upgradeTimer) { clearTimeout(upgradeTimer); upgradeTimer = null; }
      upgradePending = false;

      // Fetch the redirect URL in the background while the current video keeps playing
      const targetUrl = '/youtube-stream/' + videoId + '.mp4?itag=' + itag + '&json=1';
      console.log('[yt-player] Resolving new quality URL in background...');
      
      fetch(targetUrl)
        .then(res => res.json())
        .then(data => {
          if (!data.url) throw new Error('No URL returned');
          console.log('[yt-player] New quality URL resolved. Switching now.');
          const seekTime = v.currentTime || 0;
          const wasPlaying = !v.paused;

          // data.url contains the final resolved URL
          v.src = data.url;

          // Resume from saved position once the new source is ready
          v.addEventListener('loadedmetadata', function onReady() {
            v.removeEventListener('loadedmetadata', onReady);
            v.currentTime = seekTime;
            if (wasPlaying) v.play().catch(() => {});
          });
        })
        .catch(err => {
          console.error('[yt-player] Failed to switch quality:', err);
        });
    }

    // Fullscreen — hide nav, search, info, related when video is fullscreen
    document.addEventListener('fullscreenchange', () => {
      document.body.classList.toggle('yt-player-fullscreen', !!document.fullscreenElement)
    })
    document.addEventListener('webkitfullscreenchange', () => {
      document.body.classList.toggle('yt-player-fullscreen', !!document.webkitFullscreenElement)
    })

    // Infinite scroll for related videos
    document.addEventListener('DOMContentLoaded', () => {
      const loader = document.getElementById('scroll-loader');
      const grid = document.getElementById('related-grid');
      if (!loader || !grid) return;

      let isLoading = false;

      const observer = new IntersectionObserver((entries) => {
        if (entries[0].isIntersecting && !isLoading) {
          loadMoreRelated();
        }
      }, { rootMargin: '200px' });

      observer.observe(loader);

      async function loadMoreRelated() {
        const token = loader.getAttribute('data-token');
        const videoId = loader.getAttribute('data-videoid');
        if (!token) return;

        isLoading = true;
        loader.classList.add('active');

        try {
          const res = await fetch(`/api/youtube/related?videoId=${videoId}&continuation=${encodeURIComponent(token)}`);
          const data = await res.json();

          if (data.results && data.results.length > 0) {
            data.results.forEach(v => {
              const card = document.createElement('a');
              card.className = 'card';
              card.href = `/youtube/watch/${v.id}`;
              
              let durationHtml = '';
              if (v.duration) {
                const m = Math.floor(v.duration / 60);
                const s = String(v.duration % 60).padStart(2, '0');
                durationHtml = `<span class="duration-badge">${m}:${s}</span>`;
              }

              card.innerHTML = `
                <div class="thumb-wrap">
                  <img src="${v.thumbnail}" alt="${v.title.replace(/"/g, '&quot;')}" loading="lazy" />
                  ${durationHtml}
                </div>
                <div class="card-info">
                  <div class="card-title">${v.title}</div>
                  <div class="card-meta">${v.channel}</div>
                </div>
              `;
              grid.appendChild(card);
            });
          }

          if (data.continuationToken) {
            loader.setAttribute('data-token', data.continuationToken);
            isLoading = false;
          } else {
            loader.removeAttribute('data-token');
            observer.disconnect();
            loader.style.display = 'none';
          }
        } catch (e) {
          console.error('Failed to load related videos', e);
          isLoading = false;
        } finally {
          loader.classList.remove('active');
        }
      }
    });
  </script>
</body>
</html>
