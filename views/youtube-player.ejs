<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title><%= title %></title>

  <meta property="og:type"        content="video.movie" />
  <meta property="og:title"       content="<%= title %>" />
  <meta property="og:description" content="<%= description %>" />
  <meta property="og:url"         content="<%= pageUrl %>" />
  <% if (thumb) { %><meta property="og:image" content="<%= thumb %>" /><% } %>
  <meta property="og:video"       content="<%= videoUrl %>" />
  <meta property="og:video:type"  content="video/mp4" />
  <meta property="og:video:secure_url" content="<%= videoUrl %>" />
  <meta name="og:author" content="neerajan" />
  <meta name="author" content="neerajan" />
  <meta property="og:site_name" content="YouTube" />
  <meta property="al:android:app_name" content="YouTube" />
  <meta property="al:ios:app_name" content="YouTube" />
  <meta name="application-name" content="YouTube" />
  <meta property="og:provider" content="YOUTUBE" />

  <link rel="stylesheet" href="https://cdn.plyr.io/3.7.8/plyr.css" />
  <%- include('partials/styles') %>
  <style>
    .cinema-wrap{
      width:100%;
      max-width:1000px;
      margin:0 auto;
    }
    .video-frame{
      background:#000;
      border-radius:var(--radius-lg) var(--radius-lg) 0 0;
      overflow:hidden;
      box-shadow:0 16px 48px rgba(0,0,0,0.7);
    }
    video{width:100%;display:block;background:#000}

    .video-info{
      background:var(--surface);
      border:1px solid var(--surface-border);
      border-top:none;
      border-radius:0 0 var(--radius-lg) var(--radius-lg);
      padding:24px 28px 28px;
      position:relative;
    }
    .video-info h2{
      font-size:1.3rem;
      font-weight:700;
      color:var(--text);
      letter-spacing:-0.01em;
      line-height:1.3;
      padding-right:110px;
    }
    .video-info small{
      color:var(--text-secondary);
      font-size:0.85rem;
      font-weight:500;
    }
    .video-info > p{
      color:var(--text-secondary);
      line-height:1.65;
      font-size:0.9rem;
      margin-top:14px;
      max-width:60ch;
    }

    .btn-share{
      position:absolute;
      right:28px;
      top:24px;
      padding:8px 18px;
      border-radius:var(--radius);
      background:var(--accent);
      color:#fff;
      border:none;
      cursor:pointer;
      font-family:inherit;
      font-size:0.82rem;
      font-weight:600;
      transition:background 0.2s, transform 0.15s;
    }
    .btn-share:hover{background:var(--accent-hover)}
    .btn-share:active{transform:scale(0.96)}

    /* ── Up Next card ── */
    .up-next{
      margin-top:20px;
      padding:18px;
      background:rgba(255,255,255,0.03);
      border-radius:var(--radius);
      border:1px solid var(--surface-border);
    }
    .up-next-label{
      font-size:0.72rem;
      font-weight:700;
      color:var(--text-muted);
      text-transform:uppercase;
      letter-spacing:0.08em;
      margin-bottom:12px;
    }
    .up-next-inner{
      display:flex;gap:16px;align-items:center;flex-wrap:wrap;
    }
    .up-next-thumb{
      width:150px;border-radius:var(--radius);aspect-ratio:16/9;object-fit:cover;
    }
    .up-next-meta{flex:1;min-width:180px}
    .up-next-title{font-weight:600;font-size:0.95rem;margin-bottom:3px;color:var(--text)}
    .up-next-channel{color:var(--text-secondary);font-size:0.82rem;margin-bottom:12px}
    .up-next-btn{
      display:inline-block;
      background:var(--accent);
      color:#fff;text-decoration:none;
      padding:9px 22px;border-radius:var(--radius);
      font-family:inherit;font-weight:600;font-size:0.85rem;
      transition:background 0.2s, transform 0.15s;
    }
    .up-next-btn:hover{background:var(--accent-hover)}
    .up-next-btn:active{transform:scale(0.97)}

    /* ── Related ── */
    .related{
      margin-top:48px;
      width:100%;max-width:1000px;
      margin-left:auto;margin-right:auto;
      padding:0 40px 80px;
      position:relative;z-index:1;
    }
    .related h3{
      font-size:1.2rem;
      font-weight:700;
      color:var(--text);
      margin-bottom:20px;
      letter-spacing:-0.01em;
    }

    @media(max-width:768px){
      .video-info{padding:20px}
      .video-info h2{font-size:1.15rem;padding-right:100px}
      .btn-share{right:20px;top:20px;padding:7px 14px}
      .related{padding:0 20px 60px}
      .up-next-thumb{width:120px}
    }
    @media(max-width:480px){
      .up-next-inner{flex-direction:column;align-items:flex-start}
      .up-next-thumb{width:100%}
    }

    .loader-container {
      display: flex;
      justify-content: center;
      padding: 30px 0;
      opacity: 0;
      transition: opacity 0.3s;
    }
    .loader-container.active {
      opacity: 1;
    }
    .spinner {
      width: 32px;
      height: 32px;
      border: 3px solid var(--surface-border);
      border-top-color: var(--accent);
      border-radius: 50%;
      animation: spin 1s linear infinite;
    }
    @keyframes spin {
      to { transform: rotate(360deg); }
    }
  </style>
</head>
<body>
  <%- include('partials/nav') %>

  <main class="main-container" style="display:flex; flex-direction:column; align-items:center;">
    <div class="cinema-wrap">
      <div class="video-frame" id="player-container">
        <video id="player" playsinline webkit-playsinline preload="metadata" poster="<%= thumb || '' %>" src="<%= videoUrl %>"></video>
      </div>
      <div class="video-info">
        <button class="btn-share" onclick="navigator.clipboard.writeText(window.location.href); this.innerText='Copied!'; setTimeout(() => this.innerText='Share Link', 2000)">Share Link</button>
        <h2><%= title %></h2>
        <small><%= channel %></small>
        <p style="margin-top:12px;color:var(--text-secondary);line-height:1.65;font-size:0.9rem"><%= description %></p>
        

      </div>
    </div>
  </main>

  <% if (relatedVideos && relatedVideos.length > 0) { %>
  <div class="related" id="related-container">
    <h3>Related Videos</h3>
    <div class="grid" id="related-grid">
      <% relatedVideos.forEach(v => { %>
        <a class="card" href="/youtube/watch/<%= v.id %>">
          <div class="thumb-wrap">
            <img src="<%= v.thumbnail %>" alt="<%= v.title %>" loading="lazy" />
            <% if (v.duration) { %><span class="duration-badge"><%= Math.floor(v.duration / 60) %>:<%= String(v.duration % 60).padStart(2, '0') %></span><% } %>
          </div>
          <div class="card-info">
            <div class="card-title"><%= v.title %></div>
            <div class="card-meta"><%= v.channel %></div>
          </div>
        </a>
      <% }) %>
    </div>
    
    <% if (relatedContinuation) { %>
      <div class="loader-container" id="scroll-loader" data-token="<%= relatedContinuation %>" data-videoid="<%= videoId %>">
        <div class="spinner"></div>
      </div>
    <% } %>
  </div>
  <% } %>

  <script src="https://cdn.plyr.io/3.7.8/plyr.polyfilled.js"></script>
  <script>
    const v = document.getElementById('player');
    
    // Initialize Plyr
    const player = new Plyr(v, {
      controls: ['play-large', 'play', 'progress', 'current-time', 'mute', 'volume', 'fullscreen'],
      autoplay: true
    });

    // Infinite scroll for related videos
    document.addEventListener('DOMContentLoaded', () => {
      const loader = document.getElementById('scroll-loader');
      const grid = document.getElementById('related-grid');
      if (!loader || !grid) return;

      let isLoading = false;

      const observer = new IntersectionObserver((entries) => {
        if (entries[0].isIntersecting && !isLoading) {
          loadMoreRelated();
        }
      }, { rootMargin: '200px' });

      observer.observe(loader);

      async function loadMoreRelated() {
        const token = loader.getAttribute('data-token');
        const videoId = loader.getAttribute('data-videoid');
        if (!token) return;

        isLoading = true;
        loader.classList.add('active');

        try {
          const res = await fetch(`/api/youtube/related?videoId=${videoId}&continuation=${encodeURIComponent(token)}`);
          const data = await res.json();

          if (data.results && data.results.length > 0) {
            data.results.forEach(v => {
              const card = document.createElement('a');
              card.className = 'card';
              card.href = `/youtube/watch/${v.id}`;
              
              let durationHtml = '';
              if (v.duration) {
                const m = Math.floor(v.duration / 60);
                const s = String(v.duration % 60).padStart(2, '0');
                durationHtml = `<span class="duration-badge">${m}:${s}</span>`;
              }

              card.innerHTML = `
                <div class="thumb-wrap">
                  <img src="${v.thumbnail}" alt="${v.title.replace(/"/g, '&quot;')}" loading="lazy" />
                  ${durationHtml}
                </div>
                <div class="card-info">
                  <div class="card-title">${v.title}</div>
                  <div class="card-meta">${v.channel}</div>
                </div>
              `;
              grid.appendChild(card);
            });
          }

          if (data.continuationToken) {
            loader.setAttribute('data-token', data.continuationToken);
            isLoading = false;
          } else {
            loader.removeAttribute('data-token');
            observer.disconnect();
            loader.style.display = 'none';
          }
        } catch (e) {
          console.error('Failed to load related videos', e);
          isLoading = false;
        } finally {
          loader.classList.remove('active');
        }
      }
    });
  </script>
</body>
</html>
