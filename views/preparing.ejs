<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>Preparing <%= title %>…</title>
  <meta http-equiv="refresh" content="4">
  <%- include('partials/styles') %>
  <style>
    body{
      display:flex;align-items:center;justify-content:center;
      flex-direction:column;gap:24px;
      text-align:center;padding:32px;min-height:100dvh;
    }
    .spinner{
      width:44px;height:44px;border-radius:50%;
      border:3px solid rgba(255,255,255,0.08);
      border-top-color:var(--accent);
      animation:spin 0.8s linear infinite;
    }
    @keyframes spin{to{transform:rotate(360deg)}}
    .progress-bar{
      width:180px;height:4px;border-radius:2px;
      background:var(--surface);overflow:hidden;
    }
    .progress-bar::after{
      content:'';display:block;height:100%;width:40%;
      background:var(--accent);border-radius:2px;
      animation:slide 1.5s ease-in-out infinite;
    }
    @keyframes slide{0%{transform:translateX(-100%)}100%{transform:translateX(350%)}}
    h1{font-size:1.1rem;font-weight:600;color:var(--text)}
    p{color:var(--text-secondary);font-size:0.85rem;max-width:320px;line-height:1.6}
    a{color:var(--accent);text-decoration:none;font-size:0.85rem;font-weight:600}
    a:hover{opacity:0.8}
  </style>
</head>
<body>
  <div class="spinner"></div>
  <div class="progress-bar"></div>
  <h1>Preparing <%= title %> for playback…</h1>
  <p>This file needs a one-time conversion for phone/browser compatibility. This page will refresh automatically.</p>
  <a href="/">&larr; Back to all movies</a>
</body>
</html>
