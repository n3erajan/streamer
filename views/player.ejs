<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title><%= title %></title>

  <meta property="og:type"        content="video.movie" />
  <meta property="og:title"       content="<%= title %>" />
  <meta property="og:description" content="<%= description %>" />
  <meta property="og:url"         content="<%= pageUrl %>" />
  <% if (thumb) { %><meta property="og:image" content="<%= BASE_URL %><%= thumb %>" /><% } %>
  <meta property="og:video"       content="<%= BASE_URL %><%= video %>" />
  <meta property="og:video:type"  content="video/mp4" />
  <meta property="og:video:secure_url" content="<%= BASE_URL %><%= video %>" />
  <meta name="og:author" content="neerajan" />
  <meta name="author" content="neerajan" />
  <meta property="og:site_name" content="neerajan" />

  <%- include('partials/styles') %>
  <style>
    .cinema-wrap{
      width:100%;
      max-width:1000px;
      margin:0 auto;
    }
    .video-frame{
      background:#000;
      border-radius:var(--radius-lg) var(--radius-lg) 0 0;
      overflow:hidden;
      box-shadow:0 16px 48px rgba(0,0,0,0.7);
    }
    video{width:100%;display:block;background:#000}

    .video-info{
      background:var(--surface);
      border:1px solid var(--surface-border);
      border-top:none;
      border-radius:0 0 var(--radius-lg) var(--radius-lg);
      padding:24px 28px 28px;
      position:relative;
    }
    .video-info h2{
      font-size:1.3rem;
      font-weight:700;
      color:var(--text);
      letter-spacing:-0.01em;
      line-height:1.3;
      padding-right:110px;
    }
    .video-info .year{
      color:var(--text-secondary);
      font-size:0.85rem;
      font-weight:500;
      margin-top:4px;
    }
    .video-info .desc{
      color:var(--text-secondary);
      line-height:1.65;
      font-size:0.9rem;
      margin-top:14px;
      max-width:60ch;
    }

    .btn-share{
      position:absolute;
      right:28px;
      top:24px;
      padding:8px 18px;
      border-radius:var(--radius);
      background:var(--accent);
      color:#fff;
      border:none;
      cursor:pointer;
      font-family:inherit;
      font-size:0.82rem;
      font-weight:600;
      transition:background 0.2s, transform 0.15s;
    }
    .btn-share:hover{background:var(--accent-hover)}
    .btn-share:active{transform:scale(0.96)}

    @media(max-width:768px){
      .video-info{padding:20px}
      .video-info h2{font-size:1.15rem;padding-right:100px}
      .btn-share{right:20px;top:20px;padding:7px 14px}
    }
  </style>
</head>
<body>
  <%- include('partials/nav') %>

  <main class="main-container" style="display:flex;flex-direction:column;align-items:center;">
    <div class="cinema-wrap">
      <div class="video-frame">
        <video id="player" controls playsinline webkit-playsinline preload="metadata"
               poster="<%= thumb || '' %>" width="100%" src="<%= video %>">
          <source src="<%= video %>" type="video/mp4" />
        </video>
      </div>
      <div class="video-info">
        <button class="btn-share" onclick="navigator.clipboard.writeText(window.location.href); this.innerText='Copied!'; setTimeout(() => this.innerText='Share Link', 2000)">Share Link</button>
        <h2><%= title %></h2>
        <% if (year) { %><div class="year"><%= year %></div><% } %>
        <p class="desc"><%= description %></p>
      </div>
    </div>
  </main>

  <script>
    const v = document.getElementById('player')
    v.addEventListener('play',    () => console.log('play'))
    v.addEventListener('pause',   () => console.log('pause'))
    v.addEventListener('seeked',  () => console.log('seeked'))
    v.addEventListener('timeupdate', () => console.log('time', v.currentTime))
    v.addEventListener('ended',   () => console.log('ended'))
  </script>
</body>
</html>
