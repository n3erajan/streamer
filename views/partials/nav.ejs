<nav class="global-nav">
  <div class="nav-container">
    <a href="/" class="nav-logo">
      <span class="nav-logo-mark">
        <svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
      </span>
      StreamBox
    </a>
    <% if (typeof showYoutubeSearch !== 'undefined' && showYoutubeSearch) { %>
    <form class="nav-search" action="/youtube" method="GET" onsubmit="if(this.q.value.trim()) this.action='/youtube?q='+encodeURIComponent(this.q.value.trim())+'&search=Search'; else return false">
      <svg class="nav-search-icon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
      <input type="text" name="q" placeholder="Search YouTube…" autocomplete="off" value="<%= typeof query !== 'undefined' ? query : '' %>">
    </form>
    <% } else { %>
      <div style="flex:1"></div>
    <% } %>
    <div class="nav-links">
      <a href="/" class="nav-link">Movies</a>
      <a href="/youtube" class="nav-link">YouTube</a>
    </div>
  </div>
</nav>
